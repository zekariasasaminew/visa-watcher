# ── Visa Portal Credentials ──────────────────────────────────────────────────
# Your login email for https://ais.usvisa-info.com
VISA_EMAIL=

# Your login password
VISA_PASSWORD=

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Set to false ONLY when you want the script to actually reschedule.
# Leave as true to monitor-only (recommended until you are ready to book).
DRY_RUN=true

# ── Gmail SMTP (for email alerts) ─────────────────────────────────────────────
# Gmail address used to SEND alerts (enable "App Passwords" in Google Account)
EMAIL_USER=

# The App Password generated at https://myaccount.google.com/apppasswords
# (NOT your regular Gmail password)
EMAIL_PASS=
